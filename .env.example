# =============================================================================
# Python Q&A Assistant — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# Groq API Key (get one free at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Embedding model (uses ChromaDB's built-in ONNX model by default, no PyTorch needed)
# Set to a HuggingFace model name if sentence-transformers is installed
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector store & retrieval
VECTORSTORE_PATH=./vectorstore
RETRIEVAL_TOP_K=5
RETRIEVAL_CANDIDATES=20
RELEVANCE_THRESHOLD=0.25
RERANK_WEIGHT_SIMILARITY=0.75
RERANK_WEIGHT_SCORE=0.25
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=info
